{
  "name": "vscode-tingly-box",
  "displayName": "Tingly Box AI Model Provider",
  "description": "Connect VSCode Chat to OpenAI, Anthropic, and other AI model providers",
  "version": "0.0.1",
  "publisher": "tinglybox",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "openai",
    "anthropic",
    "llm",
    "language model",
    "gpt",
    "claude"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "tinglybox-vscode",
        "displayName": "Tingly Box VSCode",
        "managementCommand": "tinglybox.manage"
      }
    ],
    "commands": [
      {
        "command": "tinglybox.manage",
        "title": "Tingly Box VSCode: Manage Settings",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.status",
        "title": "Tingly Box VSCode: Show Provider Status",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.fetchModels",
        "title": "Tingly Box VSCode: Fetch Models",
        "category": "Tingly Box"
      }
    ],
    "configuration": {
      "title": "Tingly Box VSCode",
      "properties": {
        "tinglybox.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging in output channel",
          "order": 1
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
