{
  "name": "vscode-tingly-box",
  "displayName": "Tingly Box For VS Code",
  "description": "Bring Your Own Key (BYOK) for VSCode GitHub Copilot Chat - Connect any OpenAI/Anthropic compatible provider with your own API keys",
  "version": "0.260423.2",
  "publisher": "tingly-dev",
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.104.0"
  },
  "icon": "./resource/icon.png",
  "repository": {
    "url": "https://github.com/tingly-dev/vscode-tingly-box"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "openai",
    "anthropic",
    "llm",
    "language model",
    "gpt",
    "claude"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "tinglybox-vscode",
        "displayName": "Tingly Box",
        "configuration": {
          "command": "tinglybox.openConfigWebview"
        }
      }
    ],
    "commands": [
      {
        "command": "tinglybox.startServer",
        "title": "Start Server",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.stopServer",
        "title": "Stop Server",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.openWebUI",
        "title": "Open Web UI (System Browser)",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.openWebUIInBrowser",
        "title": "Open Web UI (Integrated Browser)",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.status",
        "title": "Show Status",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.fetchModels",
        "title": "Fetch Models",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.manageLanguageModels",
        "title": "Manage Language Models",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.resetConfig",
        "title": "Reset Configuration",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.openConfigWebview",
        "title": "Manage Settings",
        "category": "Tingly Box"
      },
      {
        "command": "tinglybox.manage",
        "title": "Manage Settings (Quick Input)",
        "category": "Tingly Box",
        "enablement": "false"
      }
    ],
    "configuration": {
      "title": "Tingly Box For VS Code",
      "properties": {
        "tinglybox.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging in output channel",
          "order": 1
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile:tsc": "tsc -p ./ --noEmit",
    "pretest": "pnpm run compile:tsc && pnpm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.15",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.73.1"
  }
}
